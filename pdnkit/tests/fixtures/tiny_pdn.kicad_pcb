(kicad_pcb
    (version 20240108)
    (generator "pdnkit-fixture")
    (general
        (thickness 1.6)
    )
    (paper "A4")
    (layers
        (0 "F.Cu" signal)
        (31 "B.Cu" signal)
        (32 "B.Adhes" user)
        (33 "F.Adhes" user)
        (34 "B.Paste" user)
        (35 "F.Paste" user)
        (36 "B.SilkS" user)
        (37 "F.SilkS" user)
        (38 "B.Mask" user)
        (39 "F.Mask" user)
        (44 "Edge.Cuts" user)
    )
    (net 0 "")
    (net 1 "GND")
    (net 2 "+3V3")

    (footprint "Connector:PinHeader_1x02"
        (at 5 20)
        (pad "1" thru_hole circle
            (at 0 0)
            (size 1.7 1.7)
            (drill 1)
            (layers "*.Cu" "*.Mask")
            (net 2 "+3V3")
        )
        (pad "2" thru_hole circle
            (at 0 2.54)
            (size 1.7 1.7)
            (drill 1)
            (layers "*.Cu" "*.Mask")
            (net 1 "GND")
        )
    )

    (footprint "Resistor_SMD:R_0603"
        (at 12 20)
        (pad "1" smd rect
            (at -0.8 0)
            (size 0.8 0.95)
            (layers "F.Cu" "F.Paste" "F.Mask")
            (net 2 "+3V3")
        )
        (pad "2" smd rect
            (at 0.8 0)
            (size 0.8 0.95)
            (layers "F.Cu" "F.Paste" "F.Mask")
            (net 1 "GND")
        )
    )

    (segment
        (start 5 20) (end 11.2 20)
        (width 0.5)
        (layer "F.Cu")
        (net 2)
    )

    (via
        (at 7 22)
        (size 0.8)
        (drill 0.4)
        (layers "F.Cu" "B.Cu")
        (net 1)
    )

    (zone
        (net 2)
        (net_name "+3V3")
        (layer "F.Cu")
        (polygon
            (pts (xy 0 15) (xy 20 15) (xy 20 25) (xy 0 25))
        )
        (filled_polygon
            (layer "F.Cu")
            (pts (xy 0.5 15.5) (xy 19.5 15.5) (xy 19.5 24.5) (xy 0.5 24.5))
        )
    )

    (zone
        (net 1)
        (net_name "GND")
        (layer "B.Cu")
        (polygon
            (pts (xy 0 15) (xy 20 15) (xy 20 25) (xy 0 25))
        )
        (filled_polygon
            (layer "B.Cu")
            (pts (xy 0.5 15.5) (xy 19.5 15.5) (xy 19.5 24.5) (xy 0.5 24.5))
        )
    )

    (gr_line (start 0 15) (end 20 15) (layer "Edge.Cuts") (width 0.1))
    (gr_line (start 20 15) (end 20 25) (layer "Edge.Cuts") (width 0.1))
    (gr_line (start 20 25) (end 0 25) (layer "Edge.Cuts") (width 0.1))
    (gr_line (start 0 25) (end 0 15) (layer "Edge.Cuts") (width 0.1))
    (gr_arc (start 5 5) (mid 7 7) (end 9 5) (layer "Edge.Cuts") (width 0.1))
    (gr_circle (center 15 8) (end 17 8) (layer "Edge.Cuts") (width 0.1))
)
